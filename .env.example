# Resend API Configuration
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
# The "from" email address (must be verified in Resend)
# For development, you can use: onboarding@resend.dev
# For production, use your verified domain email
EMAIL_FROM=Seguros <noreply@yourdomain.com>

# Agent Email Addresses
# Comma-separated list of email addresses to receive quote requests
# Example: agent1@yourdomain.com,agent2@yourdomain.com
AGENT_EMAILS=agent@example.com
